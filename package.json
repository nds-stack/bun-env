{
  "name": "@nds-stack/bun-env",
  "version": "0.1.0-alpha.0",
  "description": "Environment variable loader & validator for Bun — schema-based, type coercion, zero dependencies",
  "author": "nds-stack <nds.stack@gmail.com>",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "bench": "bun run bench/env.bench.ts",
    "prepublishOnly": "bun run lint && bun run typecheck && bun test && bun run build",
    "build": "bun build ./src/index.ts --outdir=./dist --target=bun --format=esm && tsc -p tsconfig.build.json",
    "clean": "bun run --bun \"rm -rf dist\""
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nds-stack/bun-env.git"
  },
  "bugs": {
    "url": "https://github.com/nds-stack/bun-env/issues"
  },
  "homepage": "https://github.com/nds-stack/bun-env#readme",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "eslint": "^10.3.0",
    "typescript-eslint": "^8.59.2"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "keywords": [
    "bun",
    "env",
    "environment",
    "validator",
    "config",
    "typescript"
  ],
  "license": "MIT"
}
